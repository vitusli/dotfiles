ctrl + alt + cmd + shift - m : yabai -m config focus_follows_mouse off
ctrl + alt + cmd - m : yabai -m config focus_follows_mouse autoraise

# focus window under cursor
ctrl + alt + cmd - n : yabai -m window --focus mouse

ctrl + alt + cmd - v : yabai -m window --toggle split

#resize
ctrl + cmd - h : yabai -m window west --resize right:-60:0 2> /dev/null || yabai -m window --resize right:-60:0
ctrl + cmd - j : yabai -m window north --resize bottom:0:60 2> /dev/null || yabai -m window --resize bottom:0:60
ctrl + cmd - k : yabai -m window south --resize top:0:-60 2> /dev/null || yabai -m window --resize top:0:-60
ctrl + cmd - l : yabai -m window east --resize left:60:0 2> /dev/null || yabai -m window --resize left:60:0

#focus
ctrl + alt + cmd - l: yabai -m window --focus east  || yabai -m window --focus stack.next|| yabai -m space --focus next #|| yabai -m window --focus stack.first
ctrl + alt + cmd - h: yabai -m window --focus west  || yabai -m window --focus stack.prev|| yabai -m space --focus prev #|| yabai -m window --focus stack.last
ctrl + alt + cmd - k: yabai -m window --focus north || yabai -m display --focus recent
ctrl + alt + cmd - j: yabai -m window --focus south || yabai -m display --focus recent

ctrl + alt + cmd - f: yabai -m window --toggle zoom-fullscreen
ctrl + alt + cmd + shift - f: yabai -m window --toggle zoom-parent

#swap windows
ctrl + alt + cmd + shift - l: yabai -m window --swap east || yabai -m window --space next
ctrl + alt + cmd + shift - h: yabai -m window --swap west || yabai -m window --space prev
ctrl + alt + cmd + shift - k: yabai -m window --swap north || yabai -m window --display recent; yabai -m display --focus recent
ctrl + alt + cmd + shift - j: yabai -m window --swap south || yabai -m window --display recent; yabai -m display --focus recent

# send window to next space and focus it
# ctrl + cmd - left : yabai -m window --space prev; yabai -m space --focus prev
# ctrl + cmd - right : yabai -m window --space next; yabai -m space --focus next

# focus space
#ctrl - left : yabai -m space --focus prev || yabai -m space --focus last
#ctrl - right : yabai -m space --focus next || yabai -m space --focus first
cmd + alt + ctrl - s : yabai -m space --focus recent || yabai -m space --focus next

# alternate focus between displays
cmd + alt + ctrl - d : labai -m display --focus recent || yabai -m display --focus next
# move window to display focused before the current one
cmd + alt + ctrl + shift - d : yabai -m window --display recent || yabai -m window --display next

ctrl + alt + cmd - return : yabai -m space --create
ctrl + alt + cmd + shift - return : yabai -m space --destroy

alt - y : yabai -m space --mirror x-axis
alt - x : yabai -m space --mirror y-axis

#Apps
ctrl + alt + cmd - t : open -a Alacritty

#Services
#ctrl + alt + cmd - w : yabai -m window --toggle float
ctrl + alt + cmd - e : yabai -m space --balance
ctrl + alt + cmd - r : yabai --restart-service

cmd + ctrl + alt  - space : yabai -m space --layout "$(yabai -m query --spaces --space | jq -r 'if .type == "bsp" then "stack" else "bsp" end')"; space_number=$(yabai -m query --spaces --space | jq -r .index); yabai_mode=$(yabai -m query --spaces --space | jq -r .type)

