,"^V",21,536871490]],["^15",[999,"^U",21,536871491]],["^15",[999,"^?",["^ "],536871490]],["^15",[999,"^;","~u667d82a9-9137-42ef-b1c3-5050aab2fa66",536871490]],["^15",[1000,"^Q","",536871493]],["^15",[1000,"^O","^16",536871493]],["^15",[1000,"^@",false,536871493]],["^15",[1000,"^F",81,536871493]],["^15",[1000,"^X",81,536871493]],["^15",[1000,"^V",81,536871493]],["^15",[1000,"^U",81,536871494]],["^15",[1000,"^?",["^ "],536871493]],["^15",[1000,"^;","~u667d82aa-1018-4679-8783-58e587b0a931",536871493]],["^15",[1002,"^Q","Achte auf dich",536871559]],["^15",[1002,"^O","^16",536871518]],["^15",[1002,"^F",991,536871518]],["^15",[1002,"^X",928,536871518]],["^15",[1002,"^V",991,536871520]],["^15",[1002,"^U",21,536871519]],["^15",[1002,"^U",23,536871519]],["^15",[1002,"^U",79,536871519]],["^15",[1002,"^U",81,536871519]],["^15",[1002,"^U",85,536871519]],["^15",[1002,"^U",928,536871519]],["^15",[1002,"^?",["^ "],536871559]],["^15",[1002,"^;","~u667d83dd-63e6-45b0-b6d9-2228242f09b4",536871518]],["^15",[1003,"^Q","Sag auch mal Nein",536871531]],["^15",[1003,"^O","^16",536871527]],["^15",[1003,"^F",1002,536871527]],["^15",[1003,"^X",928,536871527]],["^15",[1003,"^V",991,536871527]],["^15",[1003,"^U",21,536871528]],["^15",[1003,"^U",23,536871528]],["^15",[1003,"^U",79,536871528]],["^15",[1003,"^U",81,536871528]],["^15",[1003,"^U",85,536871528]],["^15",[1003,"^U",928,536871528]],["^15",[1003,"^?",["^ "],536871531]],["^15",[1003,"^;","~u667d83df-3b1b-42b4-9e09-93608955945c",536871527]],["^15",[1004,"^12",2,536871558]],["^15",[1005,"^12",2,536871563]],["^15",[1006,"^3","- [[MPI]]\n\t- [[Work in progress]]\n\t\t- Drei Ansichten: Lab, Demo, NOVA viewport\n- ### [[Protokoll]]\n  people:: [[Tom Schmiedel]]\n  projekt:: [[MPI]] \n  tags:: [[Internal Update]]\n\t- Was macht die Pumpe?\n\t- Welche Signale braucht die Pumpe?\n\t\t- An/Aus\n\t\t  :LOGBOOK:\n\t\t  CLOCK: [2024-07-04 Thu 16:02:58]--[2024-07-04 Thu 16:02:58] =>  00:00:00\n\t\t  :END:\n\t\t- Welcher Schlauch ist wann aktiv? Kann ich auswählen?\n\t\t- Pump-Richtung\n\t- Signale - Möglichkeit:\n\t\t- Wandelskript bei uns im Wandelscript\n\t\t  logseq.order-list-type:: number\n\t\t- Labview bei Kyle\n\t\t  logseq.order-list-type:: number\n\t- Was macht Kyle mit der Pumpe?\n\t- Wo kommt das Reinigungsmittel her?\n\t- [[Mail]]\n\t\t- Von [[Tom Schmiedel]] an [[Kyle Wellmerling]]\n\t\t\t- How do you control the pump? I think over LabView à USB, correct?\n\t\t\t- What commands you are using to control the pump? (e.g. start pump (H), stop pump (I),…) Do you have like a flow chart for the communication?\n\t\t\t- Were you able to select the pipe in which the liquid is pumped or does the pump pumps the liquid through all connected pipes at the same time?\n\t\t\t  For the Wandelbots integration we have 2 possibilities:\n\t\t\t- We integrate the pump via RS232 in our system and could control the pump independent.\n\t\t\t- We will provide several (you have to tell us how many) inputs and outputs (e.g. via relay) and you integrate them into LabView. \n\t\t\t  What way do you prefer?\n- [[Omniverse]]\n\t- [[Stored knowledge]]\n\t\t- [[Endeffektor]]\n\t\t\t- Erst Endeffektor auswählen, dann 6. Glied\n\t\t\t- Create/Physics/Joint/Fixed Joint\n\t\t\t- Collider erstellen über Add/Physics/Rigid body - unbedingt auf dem obersten Xform\n\t\t\t- tool_endeffektor anwählen, link_06 mit strg auswählen - create fix joints\n\t\t\t- Tool zeigt in X\n\t\t- Jogging funktioniert nur im Root Layer, nicht in anderen Layern\n\t\t- [Camera Animation Extension]({{video https://www.youtube.com/watch?v=mAcFVeb0MsE}})\n- ### TODOs\n\t- [[TODO/General]]\n\t\t- DONE VPN",536872121]],["^15",[1006,"^1@",1720099860520,536871564]],["^15",[1006,"^1A","~m1720158816517",536872120]],["^15",[1006,"^Z","journals/2024_07_04.md",536871564]],["^15",[1007,"^K",1720099860518,536871564]],["^15",[1007,"^[",1006,536871564]],["^15",[1007,"^N",20240704,536871564]],["^15",[1007,"^@",true,536871564]],["^15",[1007,"^Y","2024-07-04",536871564]],["^15",[1007,