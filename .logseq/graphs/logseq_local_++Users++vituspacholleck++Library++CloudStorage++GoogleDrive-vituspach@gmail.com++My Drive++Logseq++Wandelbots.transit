",28,536870916]],["^15",[810,"^U",809,536870916]],["^15",[810,"^H",4,536870916]],["^15",[810,"^H",7,536870916]],["^15",[810,"^H",28,536870916]],["^15",[810,"^;","~u6694c4e8-516c-4f8b-a3a4-701e7006d887",536870916]],["^15",[811,"^3","- In diesem Graph schreibe ich Protokolle\n- ... und lerne dabei LogSeq\n- ### [[Protokoll]]\n  people:: [[Frank Mühlbauer]]\n  projekt:: [[Weekly OV]]\n  collapsed:: true\n\t- Empfiehlt mich statt auf drei/vier eher auf zwei/drei Projekte einzulassen\n\t  :LOGBOOK:\n\t  CLOCK: [2024-05-29 Wed 09:46:04]--[2024-05-29 Wed 09:46:05] =>  00:00:01\n\t  CLOCK: [2024-05-29 Wed 09:46:07]--[2024-05-29 Wed 09:46:09] =>  00:00:02\n\t  CLOCK: [2024-05-29 Wed 09:46:12]--[2024-05-29 Wed 09:46:13] =>  00:00:01\n\t  CLOCK: [2024-05-29 Wed 09:46:14]--[2024-05-29 Wed 09:46:15] =>  00:00:01\n\t  CLOCK: [2024-05-29 Wed 09:46:17]--[2024-05-29 Wed 09:46:18] =>  00:00:01\n\t  :END:\n\t- Meine Woche war schon am Limit von der Kapazität\n\t- Ich solle jeden Tag eine halbe Stunde in die [[Dokumentation]] investieren\n\t- Gedanken über den [[Zeitplan]] machen - was ist nötig für die [[Abgabe]]\n- [[Mail]] an [Pumpenhersteller](https://www.fishersci.ch/shop/products/reglo-independent-channel-control-icc-peristaltic-pumps-8/p-7190465)\n  collapsed:: true\n\t- Sehr geehrte Damen und Herren\n\t  mein Name ist Vitus Pacholleck und ich arbeite für die Wandelbots GmbH.\n\t  Wir arbeiten derzeit mit einem namenhaften Forschungsinstituts zusammen und bauen einen digitalen Zwilling eines Forschungslabors. \n\t  Der Kunde arbeitet aktuell mit Ihrer Pumpe \"Ismatec™ Reglo Independent Channel Control (ICC)-Peristaltikpumpen\" und möchte diese Pumpe dort digital dargestellt haben. Aktuell verwenden wir einen Platzhalter.\n\t  Darum möchten möchten wir Sie bitten, uns ein reduziertes CAD-Modell des genannten Mikroskops zur Verfügung zu stellen. Dabei geht es nicht um die Funktion, sondern rein um die Visualisierung - die sichtbaren Komponenten sind also ausreichend.\n\t  Über einen Vorschlag Ihrerseits würden wir uns sehr freuen. Die Renderings senden wir Ihnen gerne auf Anfrage zu.\n\t  Mit freundlichen Grüßen,\n\t  Vitus Pacholleck",536870916]],["^15",[811,"^1@",1721025768775,536870916]],["^15",[811,"^Z","journals/2024_05_28.md",536870916]],["^15",[812,"^K",1721025768775,536870916]],["^15",[812,"^@",false,536870916]],["^15",[812,"^Y","abgabe",536870916]],["^15",[812,"^11","Abgabe",536870916]],["^15",[812,"^B",1721025768775,536870916]],["^15",[812,"^;","~u6694c4e8-7500-461c-b397-3dcc334add6c",536870916]],["^15",[813,"^K",1721025768775,536870916]],["^15",[813,"^@",false,536870916]],["^15",[813,"^Y","zeitplan",536870916]],["^15",[813,"^11","Zeitplan",536870916]],["^15",[813,"^B",1721025768775,536870916]],["^15",[813,"^;","~u6694c4e8-7f9c-4597-803b-87c5fd5f5233",536870916]],["^15",[814,"^K",1721025768774,536870916]],["^15",[814,"^[",811,536870916]],["^15",[814,"^N",20240528,536870916]],["^15",[814,"^@",true,536870916]],["^15",[814,"^Y","2024-05-28",536870916]],["^15",[814,"^11","2024-05-28",536870916]],["^15",[814,"^B",1721025768774,536870916]],["^15",[814,"^;","~u6694c4e8-deb3-4de9-aac4-813f5a07fd17",536870916]],["^15",[815,"^K",1721025768775,536870916]],["^15",[815,"^@",false,536870916]],["^15",[815,"^Y","dokumentation",536870916]],["^15",[815,"^11","Dokumentation",536870916]],["^15",[815,"^B",1721025768775,536870916]],["^15",[815,"^;","~u6694c4e8-d6e7-496b-b505-9a9db48340d4",536870916]],["^15",[816,"^Q","Empfiehlt mich statt auf drei/vier eher auf zwei/drei Projekte einzulassen\n:LOGBOOK:\nCLOCK: [2024-05-29 Wed 09:46:04]--[2024-05-29 Wed 09:46:05] =>  00:00:01\nCLOCK: [2024-05-29 Wed 09:46:07]--[2024-05-29 Wed 09:46:09] =>  00:00:02\nCLOCK: [2024-05-29 Wed 09:46:12]--[2024-05-29 Wed 09:46:13] =>  00:00:01\nCLOCK: [2024-05-29 Wed 09:46:14]--[2024-05-29 Wed 09:46:15] =>  00:00:01\nCLOCK: [2024-05-29 Wed 09:46:17]--[2024-05-29 Wed 09:46:18] =>  00:00:01\n:END:",536870916]],["^15",[816,"^O","^16",536870916]],["^15",[816,"^F",822,536870916]],[