webkit-scrollbar {\n  display: none;\n}\n\n/* hide scrollbars */\n::-webkit-scrollbar-thumb {\n  border-radius: 20px;\n  border: 16px solid transparent;\n  background-clip: content-box;\n}\n\n/* Hide the Go back button */\nbutton.nav-left {\n  display: none !important;\n}\n\n/* Hide the Go forward button */\nbutton.nav-right {\n  display: none !important;\n}\n\n/* hide help button */\n.cp__sidebar-help-btn {\n  display: none;\n} \n\n/* hide titlebar icons */\na.nav-left,\na.nav-right {\n  display: none;\n}\n\n/* Hide the Toggle right sidebar button */\nbutton.toggle-right-sidebar {\n  display: none !important;\n}\n\n/* Hide the left-sidebar button */\n.cp__header-left-menu {\n    display: none !important;\n}\n\n/* hide new page button */\n.new-page {\n  display: none;\n}\n\n/* Hide new page button */\nfooter.px-2.create .new-page-link {\n  display: none !important;\n}\n\n/* Hide the search button */\n#search-button {\n    display: none !important;\n}\n\nbutton[title=\"Home\"] {\n    display: none !important;\n}\n\n/* hide favorites title */\n.favorites>div>div:first-of-type {\n  display: none !important;\n}\n\n.favorites>li>a {\n  color: var(--text-quarternary) !important;\n}\n\n/* hide favorites icons */\n.page-icon>i {\n  display: none;\n}\n\n/* hide recents */\n.recent {\n  display: none; !important;\n}\n\n/* checkboxes */\n.form-checkbox {\n  border-radius: 4px;\n  border: 1px solid var(--ls-checkbox-border-color);\n  background-color: var(--ls-page-checkbox-color);\n}\n\n.form-checkbox.checked,\n.form-checkbox:checked {\n  background-color: #007aff;\n  border-color: hsl(211, 100%, 40%);\n}\n",536870915]],["^15",[18,"~:file/created-at",1721025768784,536870916]],["^15",[18,"^Z","logseq/custom.css",536870915]],["^15",[19,"^3","### TODOs\n\t- [[TODO/General]]\n\t\t- DONE Rhino installieren\n\t\t  :LOGBOOK:\n\t\t  CLOCK: [2024-07-15 Mon 12:13:23]--[2024-07-15 Mon 12:13:24] =>  00:00:01\n\t\t  :END:\n\t\t- DONE Rhino License checken aufm anderen PC\n\t\t- Bei Mandy bedanken\n\t\t\t- flow\n\t\t\t- toggl\n\t- [[TODO/MPI]]\n\t\t- DONE GoPro mobilisieren: [[Shawn Claude]]\n\t\t  :LOGBOOK:\n\t\t  CLOCK: [2024-07-15 Mon 15:41:18]--[2024-07-15 Mon 15:41:19] =>  00:00:01\n\t\t  :END:\n\t\t\t- Wer hat das schon mal gemacht?\n\t\t- Mit [[Nina Brkanovic]] absprechen für Termin mit [[Kyle Wellmerling]]\n\t\t\t- DONE Mittwoch\n\t\t\t- Kyle bitten, in [[Tom Schmiedel]]s Mail zu gucken oder anrufen\n\t\t- Mit [[Thorsten Pflueger]] absprechen\n\t\t\t- DONE Ausgeschnittener Schaumstoff (Tastatur)\n\t\t\t  :LOGBOOK:\n\t\t\t  CLOCK: [2024-07-15 Mon 16:58:56]--[2024-07-15 Mon 16:58:56] =>  00:00:00\n\t\t\t  :END:\n\t\t\t- Endeffektor 3D-Druckteil (Pipetting Mount)\n\t\t\t\t- Vorbereiten\n\t\t\t\t\t- 10 mm Platte\n\t\t\t\t\t- Alles aus einem Teil: Schunk-Schnellwechsler\n\t\t\t\t\t\t- SHK_SHK-050-0310410_QuickChanger.SLDPRT\n\t\t\t\t\t\t- /Users/vituspacholleck/Library/CloudStorage/OneDrive-WandelbotsGmbH/design/03_DesignStudio/04_CADLibrary/10_Endeffectors/Schunk/\n\t\t\t\t\t- Case der Pipette muss mit ran, damit nichts offen liegt\n\t\t\t\t\t\t- [[AJ Andrej Apel]] fragen bez. Feingewindemuffen\n\t\t\t\t\t\t\t- unten in Werkstatt ist der Kasten mit den Muffen\n\t\t\t\t\t- Schwalbenschwanzaufnahme für Kamera\n\t-\n\t\t-\n\t\t- DONE License InstaLOD\n\t\t  :LOGBOOK:\n\t\t  CLOCK: [2024-07-15 Mon 11:15:22]--[2024-07-15 Mon 11:15:22] =>  00:00:00\n\t\t  :END:",536872704]],["^15",[19,"^1@",1721025768478,536870916]],["^15",[19,"~:file/last-modified-at","~m1721135458553",536872703]],["^15",[19,"^Z","journals/2024_07_15.md",536870916]],["^15",[20,"^K",1721025768477,536870916]],["^15",[20,"^[",19,536870916]],["^15",[20,"^N",20240715,536870916]],["^15",[20,"^@",true,536870916]],["^15",[20,"^Y","2024-07-15",536870916]],["^15",[20,"^11","2024-07-15",536870916]],["^15",[20,"^B",1721135458266,536872701]],["^15",[20,"^;","~u6694d50e-550a-4106-92ef-a3a4e24a9b93",536870972]],["^15",[21,"^Q","### TODOs",536870920]],["^15",[21,"^O","^16",536870916]],["^15",[21,"^F",