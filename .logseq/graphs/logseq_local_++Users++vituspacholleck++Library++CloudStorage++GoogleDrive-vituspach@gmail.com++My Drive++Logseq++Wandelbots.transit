U",205,536871109]],["^15",[510,"^U",390,536871109]],["^15",[510,"^;","~u66708a6e-4df5-436d-b5a4-1eedff5d8c66",536871109]],["^15",[511,"^Q","Path Tracing",536871109]],["^15",[511,"^O","^16",536871109]],["^15",[511,"^F",485,536871109]],["^15",[511,"^X",390,536871109]],["^15",[511,"^V",485,536871109]],["^15",[511,"^U",48,536871109]],["^15",[511,"^U",269,536871109]],["^15",[511,"^U",390,536871109]],["^15",[511,"^;","~u66708a6e-2dd8-4541-a3d8-e1e1c14dc89b",536871109]],["^15",[512,"^Q","Ich brauche teilweise ein bisschen mehr Betreuung",536871109]],["^15",[512,"^O","^16",536871109]],["^15",[512,"^F",510,536871109]],["^15",[512,"^X",390,536871109]],["^15",[512,"^V",475,536871109]],["^15",[512,"^U",205,536871109]],["^15",[512,"^U",390,536871109]],["^15",[512,"^;","~u66708a6e-a3b1-41cb-9b66-6704542cd995",536871109]],["^15",[513,"^Q","DONE Halterung Tips",536871109]],["^15",[513,"^O","^16",536871109]],["^15",[513,"^F",488,536871109]],["^15",[513,"^10","DONE",536871109]],["^15",[513,"^X",390,536871109]],["^15",[513,"^V",516,536871109]],["^15",[513,"^U",4,536871109]],["^15",[513,"^U",7,536871109]],["^15",[513,"^U",80,536871109]],["^15",[513,"^U",390,536871109]],["^15",[513,"^H",7,536871109]],["^15",[513,"^;","~u66708a6e-3b4f-4fef-9375-183ce767ed1b",536871109]],["^15",[514,"^Q","Die Zeit muss ich jezt haben, sonst kann ich nicht weiter machen",536871109]],["^15",[514,"^O","^16",536871109]],["^15",[514,"^F",468,536871109]],["^15",[514,"^X",390,536871109]],["^15",[514,"^V",468,536871109]],["^15",[514,"^U",205,536871109]],["^15",[514,"^U",390,536871109]],["^15",[514,"^;","~u66708a6e-5a1c-47b5-9b58-56a1c8d2f23e",536871109]],["^15",[515,"^Q","jemanden, der mir zeigt, wo die Tools sind und mir zeigt, was ich beachten muss",536871109]],["^15",[515,"^O","^16",536871109]],["^15",[515,"^F",494,536871109]],["^15",[515,"^X",390,536871109]],["^15",[515,"^V",494,536871109]],["^15",[515,"^U",205,536871109]],["^15",[515,"^U",390,536871109]],["^15",[515,"^;","~u66708a6e-2889-46ed-8d4b-60565e5799a4",536871109]],["^15",[516,"^Q","Rhino: Fokus auf die Demo",536871109]],["^15",[516,"^O","^16",536871109]],["^15",[516,"^F",493,536871109]],["^15",[516,"^X",390,536871109]],["^15",[516,"^V",493,536871109]],["^15",[516,"^U",4,536871109]],["^15",[516,"^U",7,536871109]],["^15",[516,"^U",80,536871109]],["^15",[516,"^U",390,536871109]],["^15",[516,"^;","~u66708a6e-aba2-4371-9578-a3731f382e18",536871109]],["^15",[517,"^3","### [[Protokoll]]\npeople:: [[Paul Weiss]] \nprojekt:: [[MPI]] \ntags:: [[Teaching]] [[Omniverse]] [[Endeffektor]] [[Stored Knowledge]]\n\t- DONE den Salat hier ordnen\n\t- ### Vorarbeit\n\t\t- Origins individuell in Rhino setzen\n\t\t\t- Transforms (Translation, Rotation) individuell festlegen\n\t\t- Alle Dateien in Omniverse öffnen und in die \"Golden Standard\" Struktur überführen\n\t- ### Hauptteil\n\t\t- In Omniverse alle Arbeitsgeräte in den Roboter_Workspace ziehen\n\t\t\t- workspace_ur5\n\t\t\t\t- tcp_xxx (tcp_tip)\n\t\t\t\t\t- mit **!_distance** messen in Rhino\n\t\t\t\t\t\t- 0 bis tcp\n\t\t\t\t- tool_xxx (tool_endeffktor)\n\t\t\t\t\t- muss an den Roboter-Flansch ran\n\t\t\t\t\t  :LOGBOOK:\n\t\t\t\t\t  CLOCK: [2024-06-12 Wed 16:51:46]\n\t\t\t\t\t  :END:\n\t\t\t\t\t\t- copy transform des ur5 über RMB\n\t\t\t\t\t\t- paste transform des ur5 in das tool_endeffektor über RMB\n\t\t\t\t\t\t\t- die Reihenfolge von Translate, Orient, Scale muss gleich sein\n\t\t- tool_xxx (tool_endeffektor) auswählen\n\t\t\t- add > physics > rigid body\n\t\t\t\t- play: fällt runter\n\t\t\t- create > xform\n\t\t\t\t- \"tcp\" nennen\n\t\t\t\t- tcp transform\n\t\t\t\t\t- add (großes, grünes plus neben dem Namen in den Properties)\n\t\t\t\t\t\t- TransformOP > \"Translate, Orient, Scale\"\n\t\t\t\t\t- die in Rhino gemessenen Werte eingeben\n\t\t\t\t\t\t- tcp xform sitzt jetzt an der gleichen Stelle, wie der Origin des tcp_ghost_teachings\n\t\t- workpiece_xxx (workpiece_endeffektor) platzieren\n\t\t- tcp_xxx_ghost_teaching (tcp_tip_ghost_teaching) an die Arbeitspunkte platzieren (duplizieren)\n\t- ### Developer Portal\n\t\t- Roboter anlegen im Developer Portal\n\t\t\t- Custom Config um tcp einzustellen\n\t\t\t\t- <DEINEINSTANZ>/api/v1/internal/ui\n\t\t\t\t\t- http://mfiobowy.instance.wandelbots.io/api/v1/internal/ui\n\t\t\t\t\t- virtual robot setup\n\t\t\t\t\t- Add TCP\n\t\t\t\t\t\t- name bei controller\n\t\t\t\t\t\t- id* ist 0\n\t\t\t\t\t\t- tcp eingeben, Winkel in rad\n\t\t\t\t\t\t\t- send API request\n- ### [[Protokoll]]\n  people:: [[Paul Weiss]] [[Frank Mühlbauer]]\n  projekt:: [[Asset Library]]\n  tags::\n  collapsed:: true\n\t- Roboter_Workspace\n\t\t- Activate Children Reorder\n\t\t- 0/0/0\n\t\t- x/y Koordinate muss beim Reinziehen in die Szene muss immer gleich sein - Agnostik\n\t\t- TCP in die richtige Richtung\n\t\t  id:: 3a0f5faf-03c4-4cec-86ce-1e32005828c4\n\t\t\t- Z nach vorne\n\t\t\t- x/y müssen wir aus dem Datenblatt rauskriegen\n\t\t- keine Collider\n\t\t- Material-Struktur\n\t\t\t- Standard finden: Material Best Practice\n\t\t\t- Licht-Studio fürs Prüfen in Omniverse und Blender\n\t\t\t- ghost teaching Material überlegen\n\t- Kabel erst mal weg; weil die später simuliert werden könnten\n\t- ### Prio\n\t\t- [[Paul Weiss]] haut Grundmodelle ins Omniverse und schickt mir die USD\n\t\t- [[Bruno Bellmann]] checkt die Orientierung\n\t\t\t- wir müssen ihm unsere Anforderungen mitteilen\n\t\t- [[Vitus Pacholleck]] kümmert sich ums Chirurgische\n\t- Excell Tabelle\n\t\t- Source of Prooth\n\t\t-\n\t- Nach der Roboter-Bibliothek kommt die Tool-Bibliothek\n\t-\n- ## [[Protokoll]]\n  people:: [[Paul Weiss]] [[Frank Mühlbauer]] [[CPS]] [[Johannes Baumgärtel]]\n  projekt:: [[SPS'24]]\n  tags:: [[Launch Concept]]\n  collapsed:: true\n\t- ### Thinkspace\n\t\t- Sehgewohnheiten brechen\n\t\t- Insel\n\t\t\t- Alles abgehängt, von oben\n\t\t\t- Roboter interagieren (Übergabe) miteinander\n\t\t\t- nicht fertig als Setup - Nutzende können mit den Robotern interagieren/manipulieren\n\t\t\t\t- Screen von der Decke abgehängt\n\t\t\t\t- Alle Robs in eigener Zelle\n\t\t\t\t- Klassische, nicht abstrakte Aufgaben\n\t\t- Tesla Beispiel: die haben ne Software und bauen ein Auto drum rum\n\t\t- Was bedeutet das für NOVA?\n\t\t- Wie stellt man Software dar?\n\t\t\t- SPS'23: Plan - Build - Operate\n\t\t\t\t- suggeriert drei Schwerpunkte\n\t\t- Was ist der Schwerpunkt unserer Software?\n\t\t- Sind wir noch auf der Suche oder verkaufen wir schon?\n\t\t\t- Die Suche ist vorbei - das transportieren wir nach außen  - wir wollen 500 user bis Ende 2024\n\t\t\t\t- **Ideen**\n\t\t\t\t\t- Wie würden ganz eingestaubte Vertriebler das verkaufen? Windows95 Boxen im Regal\n\t\t\t\t\t- Nutzende sollen Ihre eigenen Gedanken kriegen: \"Ah, das könnte ich für meine Palettier-Aufgabe nutzen!\"\n\t\t\t\t\t- Roboter in vier Farben\n\t\t\t\t\t\t- die übergeben sich gegenseitig Aufgaben\n\t\t\t\t\t\t- Pfade werden in Echtzeit geändert\n\t\t\t\t\t\t- Kollision: Roboter arbeiten umeinander rum\n\t\t\t\t\t\t\t- Vernetzung\n\t\t\t\t\t- All In-Veranstaltung: nicht zurückhalten\n\t\t\t\t\t\t- Allerdings können wir das alles noch gar nicht\n\t\t\t\t\t\t\t- Roboter Interkation\n\t\t\t\t\t\t\t- Multi Robot\n\t\t\t\t\t\t\t- Cloud\n\t\t\t\t\t\t- Wir müssen uns darauf fokussieren, was wir schon können\n\t\t\t\t\t\t\t- Anforderungen der Nutzenden beeinflussen die Software, aber wir sollten nicht sagen \"Das können wir schon.\"\n\t\t\t\t\t\t- Wir sollten zeigen: du kannst Cloud, Kabel etc pp nutzen - sonst schrecken wir Leute aus der Industrie ab\n\t\t\t- Wie würde der Messestand nächste Woche eigentlich aussehen? Was können wir jetzt schon richtig gut?\n\t\t\t\t- Repräsentieren, was wir schon können, reicht nicht - sagt CPS\n\t\t\t- Workstation\n\t\t\t\t- Omniverse Setup\n\t\t\t\t- Kollision anzeigen lassen\n\t\t\t\t- Erst planen in Omniverse - dann in die echte Welt übertragen\n\t\t\t\t- Alle Roboter in gleicher Gewichtsklasse und Preisklasse\n\t\t\t\t\t- Keine Präferenzen\n\t\t\t\t\t- Kein Univeral Robot\n\t\t\t\t\t\t- fällt aus dem Raster\n\t\t\t\t\t\t- ist für sich schon sehr weit in der Entwicklung\n\t\t\t\t\t-\n\t\t- ### Aufgaben\n\t\t\t- CAD Modell und mal gucken, ob 80qm reichen für 4 Roboter\n\t\t\t- Möbel aus Libray von [[Vitus Pacholleck]]\n\t\t\t- Auftrennen\n\t\t\t\t- Business\n\t\t\t\t- Anwendung\n-\n-\n- # [[TODOs]]",536871303]],["^15",[517,"^1@",1718651502909,536871111]],["^15",[517,"^1A","~m1719316300315",536871304]],["^15",[517,"^Z","journals/2024_06_12.md",536871111]],["^15",[518,"^K",1718651502908,536871111]],["^15",[518,"^O","^16",536871213]],["^15",[518,"^@",false,536871111]],["^15",[518,"^Y","launch concept",536871111]],["^15",[518,"^11","Launch Concept",536871111]],["^15",[518,"^B",1718651502908,536871111]],["^15",[518,"^;","~u667d4e25-9f95-40dc-b2f2-893770dfa66b",536871303]],["^15",[519,"^K",1718651502907,536871111]],["^15",[519,"^@",false,536871111]],["^15",[519,"^Y","sps'24",536871111]],["^15",[519,"^11","SPS'24",536871111]],["^15",[519,"^B",1718651502907,536871111]],["^15",[519,"^;","~u667d4e25-4735-46a3-b69b-713b92f808fd",536871303]],["^15",[520,"^K",1718651502908,536871111]],["^15",[520,"^@",false,536871111]],["^15",[520,"^Y","vitus pacholleck",536871111]],["^15",[520,"^11","Vitus Pacholleck",536871111]],["^15",[520,"^B",1718651502908,536871111]],["^15",[520,"^;","~u667d4e25-3cc7-4997-a58f-0cddac0423d0",536871303]],["^15",[521,"^K",1718651502907,536871111]],["^15",[521,"^@",false,536871111]],["^15",[521,"^Y","cps",536871111]],["^15",[521,"^11","CPS",536871111]],["^15",[521,"^B",1718651502907,536871111]],["^15",[521,"^;","~u667d4e25-7f29-46ae-add2-5e9fb4e73a26",536871303]],["^15",[522,"^K",1718651502903,536871111]],["^15",[522,"^[",517,536871111]],["^15",[522,"^N",20240612,536871111]],["^15",[522,"^@",true,536871111]],["^15",[522,"^Y","2024-06-12",536871111]],["^15",[522,"^11","2024-06-12",536871111]],["^15",[522,"^B",1718651502903,536871111]],["^15",[522,"^;","~u667d4e25-d695-463f-95e9-37eb49d12d8f",536871303]],["^15",[523,"^K",1718651502909,536871111]],["^15",[523,"^@",false,5368