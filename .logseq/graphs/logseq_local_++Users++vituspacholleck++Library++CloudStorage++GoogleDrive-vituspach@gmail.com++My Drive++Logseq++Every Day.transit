^U",404,536870916]],["^15",[412,"^;","~u667d4eec-b805-4f25-a071-3351e8a1c4f9",536870916]],["^15",[413,"^Q","DU BIST UNZUFRIEDEN",536870916]],["^15",[413,"^O","^1A",536870916]],["^15",[413,"^F",406,536870916]],["^15",[413,"^X",404,536870916]],["^15",[413,"^V",404,536870916]],["^15",[413,"^U",404,536870916]],["^15",[413,"^;","~u667d4eec-58b0-465c-9402-96b477d553a5",536870916]],["^15",[414,"^Q","Sie ist grade sehr unzufrieden. Zurück nach Dresden zu kommen fällt ihr schwer, drum reagiert sie krass - für mich ist es gerade wichtig, dass sie mal die Rolle der Tragenden übernimmt. Einfach mal sehen, dass man nicht immer nurn machen kann, was sich gerade richtig anfühlt.",536870916]],["^15",[414,"^O","^1A",536870916]],["^15",[414,"^F",407,536870916]],["^15",[414,"^X",404,536870916]],["^15",[414,"^V",404,536870916]],["^15",[414,"^U",404,536870916]],["^15",[414,"^;","~u667d4eec-1503-4372-b5bb-4ead46c631a7",536870916]],["^15",[415,"^3","- [[Coaching Session]]\n\t- Sharpening your Axe\n\t- Breath under the belly button\n\t- If you want it desperately you'll fuck it up\n\t- Love can either bind you or free you\n\t- If you jerk off when people say you're great you will be super frustrated if you can't deliver that high level constantly. Stop carrying about whether peopele say you're doing great or bad\n\t- If someone tells me I changed his life ... I don't give a fuck",536870916]],["^15",[415,"^1?",1719488236236,536870916]],["^15",[415,"^Z","journals/2024_05_27.md",536870916]],["^15",[416,"^K",1719488236236,536870916]],["^15",[416,"^[",415,536870916]],["^15",[416,"^N",20240527,536870916]],["^15",[416,"^@",true,536870916]],["^15",[416,"^Y","2024-05-27",536870916]],["^15",[416,"^11","2024-05-27",536870916]],["^15",[416,"^B",1719488236236,536870916]],["^15",[416,"^;","~u667d4eec-d7b0-4a8e-b2a1-568251854899",536870916]],["^15",[417,"^Q","[[Coaching Session]]",536870916]],["^15",[417,"^O","^1A",536870916]],["^15",[417,"^F",416,536870916]],["^15",[417,"^X",416,536870916]],["^15",[417,