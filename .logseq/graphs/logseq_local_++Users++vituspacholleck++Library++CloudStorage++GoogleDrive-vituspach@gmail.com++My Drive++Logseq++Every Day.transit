,"pages/Zuhause.md",536870916]],["^15",[535,"^Q","In der Wohnung will ich mehr Verantwortung übernehmen",536870916]],["^15",[535,"^O","^1A",536870916]],["^15",[535,"^F",452,536870916]],["^15",[535,"^X",452,536870916]],["^15",[535,"^V",452,536870916]],["^15",[535,"^U",452,536870916]],["^15",[535,"^;","~u667d4eec-77ce-426c-bb02-d5b01a10b5e6",536870916]],["^15",[536,"^Q","Im Bad stelle ich mir das so vor:",536870916]],["^15",[536,"^O","^1A",536870916]],["^15",[536,"^F",543,536870916]],["^15",[536,"^X",452,536870916]],["^15",[536,"^V",452,536870916]],["^15",[536,"^U",452,536870916]],["^15",[536,"^;","~u667d4eec-b8fc-4b26-bf50-dfe5c7a3ceb4",536870916]],["^15",[537,"^Q","",536870916]],["^15",[537,"^O","^1A",536870916]],["^15",[537,"^F",536,536870916]],["^15",[537,"^X",452,536870916]],["^15",[537,"^V",452,536870916]],["^15",[537,"^U",452,536870916]],["^15",[537,"^;","~u667d4eec-0144-4b6f-96b3-b55bac900244",536870916]],["^15",[538,"^Q","Ich möchte die Wände streichen",536870916]],["^15",[538,"^O","^1A",536870916]],["^15",[538,"^F",535,536870916]],["^15",[538,"^X",452,536870916]],["^15",[538,"^V",535,536870916]],["^15",[538,"^U",452,536870916]],["^15",[538,"^;","~u667d4eec-963b-4b5b-802c-affc0269b699",536870916]],["^15",[539,"^Q","In der Küche wünsche ich mir Ordnung und saubere Oberflächen",536870916]],["^15",[539,"^O","^1A",536870916]],["^15",[539,"^F",535,536870916]],["^15",[539,"^X",452,536870916]],["^15",[539,"^V",452,536870916]],["^15",[539,"^U",452,536870916]],["^15",[539,"^;","~u667d4eec-6dbe-4d59-8c7a-127efcd8b7ff",536870916]],["^15",[540,"^Q","Die Putztücher werden alle gewaschen nach dem Bad putzen",536870916]],["^15",[540,"^O","^1A",536870916]],["^15",[540,"^F",541,536870916]],["^15",[540,"^X",452,536870916]],["^15",[540,"^V",536,536870916]],["^15",[540,"^U",452,536870916]],["^15",[540,"^;","~u667d4eec-3a04-43b9-a261-f00a0730e9b7",536870916]],["^15",[541,"^Q","Die Dusche wird so geputzt, dass sich die Oberflächen glatt anfühlen",536870916]],["^15",[541,"^O","^1A"