	ctrl + alt + cmd + shift - m : yabai -m config focus_follows_mouse off
ctrl + alt + cmd - m : yabai -m config focus_follows_mouse autoraise


# ctrl + alt + cmd - : 
# ctrl + alt + cmd + shift - :

ctrl + alt + cmd - v : yabai -m window --toggle split

#zoom
ctrl + cmd - h : yabai -m window west --resize right:-60:0 2> /dev/null || yabai -m window --resize right:-60:0
ctrl + cmd - j : yabai -m window north --resize bottom:0:60 2> /dev/null || yabai -m window --resize bottom:0:60
ctrl + cmd - k : yabai -m window south --resize top:0:-60 2> /dev/null || yabai -m window --resize top:0:-60
ctrl + cmd - l : yabai -m window east --resize left:60:0 2> /dev/null || yabai -m window --resize left:60:0

#focus
ctrl + alt + cmd - l: yabai -m window --focus east
ctrl + alt + cmd - h: yabai -m window --focus west
ctrl + alt + cmd - k: yabai -m window --focus north
ctrl + alt + cmd - j: yabai -m window --focus south
ctrl + alt + cmd - f: yabai -m window --toggle zoom-fullscreen


#swap
ctrl + alt + cmd + shift - l: yabai -m window --swap east
ctrl + alt + cmd + shift - h: yabai -m window --swap west
ctrl + alt + cmd + shift - k: yabai -m window --swap north
ctrl + alt + cmd + shift - j: yabai -m window --swap south

#switch
ctrl + cmd - left : yabai -m window --space prev; yabai -m space --focus prev
ctrl + cmd - right : yabai -m window --space next; yabai -m space --focus next
#ctrl - left : yabai -m space --focus prev
#ctrl - right : yabai -m space --focus next

ctrl + alt + cmd + shift - 1 : yabai -m window --space  1 && yabai -m space --focus 1
ctrl + alt + cmd + shift - 2 : yabai -m window --space  2 && yabai -m space --focus 2
ctrl + alt + cmd + shift - 3 : yabai -m window --space  3 && yabai -m space --focus 3
ctrl + alt + cmd + shift - 4 : yabai -m window --space  4 && yabai -m space --focus 4
ctrl + alt + cmd + shift - 5 : yabai -m window --space  5 && yabai -m space --focus 5

ctrl + alt + cmd - 1 : yabai -m space --focus 1
ctrl + alt + cmd - 2 : yabai -m space --focus 2
ctrl + alt + cmd - 3 : yabai -m space --focus 3
ctrl + alt + cmd - 4 : yabai -m space --focus 4
ctrl + alt + cmd - 5 : yabai -m space --focus 5

#stack
ctrl + alt + cmd - up : yabai -m window --stack north
ctrl + alt + cmd - right: yabai -m window --stack east
ctrl + alt + cmd - down: yabai -m window --stack south
ctrl + alt + cmd - left: yabai -m window --stack west

#yabai stack navigator
cmd + shift - tab : yabai-stack-navigator --prev
cmd - tab : yabai-stack-navigator --next

#switch spaces 
#but sketchybar does not refresh the space number
#ctrl + alt + cmd + shift - left : yabai -m space --move prev
#ctrl + alt + cmd + shift - right : yabai -m space --move next

ctrl + alt + cmd - return : yabai -m space --create
ctrl + alt + cmd + shift - return : yabai -m space --destroy

alt - x : yabai -m space --mirror x-axis
alt - y : yabai -m space --mirror y-axis

#Apps
ctrl + alt + cmd - t : open -a Alacritty

#Services
#ctrl + alt + cmd - w : yabai -m window --toggle float
ctrl + alt + cmd - e : yabai -m space --balance
ctrl + alt + cmd - r : yabai --restart-service


