{{- if eq .chezmoi.os "windows" -}}

# This script runs when .chezmoidata.yaml or any shared config changes.
# Trigger re-run when shared configs change:
# shared/vscode/keybindings.json.tmpl: {{ include (joinPath .chezmoi.sourceDir "shared/vscode/keybindings.json.tmpl") | sha256sum }}
# shared/vscode/settings.json.tmpl: {{ include (joinPath .chezmoi.sourceDir "shared/vscode/settings.json.tmpl") | sha256sum }}
# shared/zed/keymap.json.tmpl: {{ include (joinPath .chezmoi.sourceDir "shared/zed/keymap.json.tmpl") | sha256sum }}
# shared/zed/private_settings.json.tmpl: {{ include (joinPath .chezmoi.sourceDir "shared/zed/private_settings.json.tmpl") | sha256sum }}
# shared/zen/policies.json: {{ include (joinPath .chezmoi.sourceDir "shared/zen/policies.json") | sha256sum }}

$ErrorActionPreference = "Stop"

$SourceDir = "{{ .chezmoi.sourceDir }}"

function Invoke-ElevatedPowerShell {
    param(
        [Parameter(Mandatory = $true)]
        [string]$CommandText
    )

    gsudo { Invoke-Expression $args[0] } -args $CommandText
}

Write-Host "Deploying shared app configs for windows..."

# =============================================================================
# Shared Apps
# =============================================================================

{{ range $app, $config := .shared_apps -}}
{{ $target := index $config.target "windows" -}}
{{ if $target -}}
# --- {{ $app }} ---
$TargetDir = if ([System.IO.Path]::IsPathRooted("{{ $target }}")) { "{{ $target }}" } else { Join-Path $env:USERPROFILE "{{ $target }}" }

try {
    New-Item -Path $TargetDir -ItemType Directory -Force -ErrorAction Stop | Out-Null
} catch {
    if ([System.IO.Path]::IsPathRooted("{{ $target }}") -and (Get-Command gsudo -ErrorAction SilentlyContinue)) {
        Invoke-ElevatedPowerShell -CommandText "New-Item -Path '$TargetDir' -ItemType Directory -Force | Out-Null"
    } else {
        throw
    }
}

{{ range $config.files -}}
{{ if .template -}}
$src = Join-Path $SourceDir "{{ $config.source }}/{{ .src }}"
if (Test-Path $src) {
    $dst = Join-Path $TargetDir "{{ .dst }}"
    try {
        chezmoi execute-template --file $src --output $dst
    } catch {
        if ([System.IO.Path]::IsPathRooted("{{ $target }}") -and (Get-Command gsudo -ErrorAction SilentlyContinue)) {
            $rendered = chezmoi execute-template --file $src
            $tmp = Join-Path $env:TEMP ([System.IO.Path]::GetRandomFileName())
            Set-Content -Path $tmp -Value $rendered -Encoding UTF8
            try {
                Invoke-ElevatedPowerShell -CommandText "Copy-Item -LiteralPath '$tmp' -Destination '$dst' -Force"
            } finally {
                Remove-Item -Path $tmp -Force -ErrorAction SilentlyContinue
            }
        } else {
            throw
        }
    }
} else {
    Write-Host "  ⚠ Source not found: {{ $config.source }}/{{ .src }}"
}
{{ else -}}
$src = Join-Path $SourceDir "{{ $config.source }}/{{ .src }}"
if (Test-Path $src) {
    $dst = Join-Path $TargetDir "{{ .dst }}"
    try {
        Copy-Item -Path $src -Destination $dst -Force -ErrorAction Stop
    } catch {
        if ([System.IO.Path]::IsPathRooted("{{ $target }}") -and (Get-Command gsudo -ErrorAction SilentlyContinue)) {
            Invoke-ElevatedPowerShell -CommandText "Copy-Item -LiteralPath '$src' -Destination '$dst' -Force"
        } else {
            throw
        }
    }
} else {
    Write-Host "  ⚠ Source not found: {{ $config.source }}/{{ .src }}"
}
{{ end -}}
{{ end -}}

{{- if index $config "files_windows" }}
{{ range (index $config "files_windows") -}}
$src = Join-Path $SourceDir "{{ $config.source }}/{{ .src }}"
if (Test-Path $src) {
    Copy-Item -Path $src -Destination (Join-Path $TargetDir "{{ .dst }}") -Force
} else {
    Write-Host "  ⚠ Source not found: {{ $config.source }}/{{ .src }}"
}
{{ end -}}
{{- end }}

Write-Host "  ✓ {{ $app }} → $TargetDir"

{{ end -}}
{{ end -}}

Write-Host "Shared app deployment complete!"
{{ end -}}
