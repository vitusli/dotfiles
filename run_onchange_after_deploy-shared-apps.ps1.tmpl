{{- if eq .chezmoi.os "windows" -}}

# This script runs when .chezmoidata.yaml or any shared config changes.
# Trigger re-run when shared configs change:
# shared/vscode/keybindings.json.tmpl: {{ include (joinPath .chezmoi.sourceDir "shared/vscode/keybindings.json.tmpl") | sha256sum }}
# shared/vscode/settings.json.tmpl: {{ include (joinPath .chezmoi.sourceDir "shared/vscode/settings.json.tmpl") | sha256sum }}
# shared/vscode/custom-vscode.css: {{ include (joinPath .chezmoi.sourceDir "shared/vscode/custom-vscode.css") | sha256sum }}
# shared/lazygit/config.yml: {{ include (joinPath .chezmoi.sourceDir "shared/lazygit/config.yml") | sha256sum }}
# shared/lf/lfrc.tmpl: {{ include (joinPath .chezmoi.sourceDir "shared/lf/lfrc.tmpl") | sha256sum }}
# shared/nvim/init.vim.tmpl: {{ include (joinPath .chezmoi.sourceDir "shared/nvim/init.vim.tmpl") | sha256sum }}
# shared/starship/starship.toml: {{ include (joinPath .chezmoi.sourceDir "shared/starship/starship.toml") | sha256sum }}
# shared/zed/keymap.json.tmpl: {{ include (joinPath .chezmoi.sourceDir "shared/zed/keymap.json.tmpl") | sha256sum }}
# shared/zed/private_settings.json: {{ include (joinPath .chezmoi.sourceDir "shared/zed/private_settings.json") | sha256sum }}
# shared/zen/policies.json: {{ include (joinPath .chezmoi.sourceDir "shared/zen/policies.json") | sha256sum }}

$ErrorActionPreference = "Stop"

$SourceDir = "{{ .chezmoi.sourceDir }}"

Write-Host "Deploying shared app configs for windows..."

# =============================================================================
# Shared Apps
# =============================================================================

{{ range $app, $config := .shared_apps -}}
{{ $target := index $config.target "windows" -}}
{{ if $target -}}
# --- {{ $app }} ---
$TargetDir = Join-Path $env:USERPROFILE "{{ $target }}"
New-Item -Path $TargetDir -ItemType Directory -Force | Out-Null

{{ range $config.files -}}
{{ if .template -}}
$src = Join-Path $SourceDir "{{ $config.source }}/{{ .src }}"
if (Test-Path $src) {
    $content = Get-Content -Path $src -Raw -Encoding UTF8
    $rendered = $content | chezmoi execute-template
    Set-Content -Path (Join-Path $TargetDir "{{ .dst }}") -Value $rendered -Encoding UTF8 -NoNewline
} else {
    Write-Host "  ⚠ Source not found: {{ $config.source }}/{{ .src }}"
}
{{ else -}}
$src = Join-Path $SourceDir "{{ $config.source }}/{{ .src }}"
if (Test-Path $src) {
    Copy-Item -Path $src -Destination (Join-Path $TargetDir "{{ .dst }}") -Force
} else {
    Write-Host "  ⚠ Source not found: {{ $config.source }}/{{ .src }}"
}
{{ end -}}
{{ end -}}

{{- if index $config "files_windows" }}
{{ range (index $config "files_windows") -}}
$src = Join-Path $SourceDir "{{ $config.source }}/{{ .src }}"
if (Test-Path $src) {
    Copy-Item -Path $src -Destination (Join-Path $TargetDir "{{ .dst }}") -Force
} else {
    Write-Host "  ⚠ Source not found: {{ $config.source }}/{{ .src }}"
}
{{ end -}}
{{- end }}

Write-Host "  ✓ {{ $app }} → $TargetDir"

{{ end -}}
{{ end -}}

# =============================================================================
# Special Apps
# =============================================================================

{{ if .special_apps.zen -}}
# --- zen ---
$ScoopRoot = if ($env:SCOOP) { $env:SCOOP } else { Join-Path $env:USERPROFILE "scoop" }
$ZenPaths = @(
    "C:\Program Files\Zen Browser"
    Join-Path $ScoopRoot "apps\zen-browser\current"
)
$ZenApp = $ZenPaths | Where-Object { Test-Path $_ } | Select-Object -First 1

if ($ZenApp) {
    $ZenTarget = Join-Path $ZenApp "distribution"
{{- range .special_apps.zen.files }}
    $src = Join-Path $SourceDir "{{ $.special_apps.zen.source }}/{{ .src }}"
    if (Test-Path $src) {
        try {
            gsudo powershell -NoProfile -Command "New-Item -Path '$ZenTarget' -ItemType Directory -Force | Out-Null; Copy-Item -Path '$src' -Destination (Join-Path '$ZenTarget' '{{ .dst }}') -Force"
            Write-Host "  ✓ zen → $ZenTarget"
        } catch {
            if (Get-Command gsudo -ErrorAction SilentlyContinue) {
                Write-Host "  ✗ zen: $_"
            } else {
                Write-Host "  ⚠ zen: gsudo not found. Install with: scoop install gsudo"
                Write-Host "      Manual: gsudo Copy-Item '$src' '$(Join-Path $ZenTarget '{{ .dst }}')' -Force"
            }
        }
    }
{{- end }}
} else {
    Write-Host "  ⊘ zen (not installed, skipping)"
}
{{ end -}}

Write-Host "Shared app deployment complete!"
{{ end -}}
