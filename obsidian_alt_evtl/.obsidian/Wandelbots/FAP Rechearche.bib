@report{englerStorytellingTransitionSpaces2023,
  type = {Diplomarbeit},
  title = {Storytelling in {{Transition Spaces}}},
  author = {Engler, Katharina},
  date = {2023-07-03},
  abstract = {Die Baubranche steht im gegenwärtigen globalen Kontext vor vielfältigen Herausforderungen und Veränderungen, die sich zu großen Teilen durch einen Fachkräftemangel und eine geringe Digitalisierung manifestieren. Zur Bewältigung dieser Herausforderungen wurde das Construction Future Lab als Plattform zur Erforschung und Entwicklung neuer Technologien und Innovationen für die Bauindustrie gegründet. Im Rahmen dieser Diplomarbeit wird ein mehrstufiger Forschungsprozess durchlaufen, der auf die Förderung des Wissenstransfers und das Ankommen der Nutzenden im Kontext des Construction Future Lab abzielt. Hierfür wird ein modulares Raumkonzept entwickelt, das auf partizipativen und nutzerzentrierten Designprinzipien basiert und interaktive Erfahrungen ermöglicht. Ziel ist es, das Verständnis für Entwicklungen, Produkte und Dienstleistungen in der Baubranche zu verbessern und den Bedürfnissen der Endnutzenden gerecht zu werden. Hierbei steht insbesondere das Storytelling als Methode im Fokus, um den Wissenstransfer und die Kommunikation zwischen Forschenden und Nutzenden zu fördern. Die Arbeit ist in sechs Teile gegliedert. Der erste Teil befasst sich mit der Hintergrundforschung, einschließlich des Construction Future Lab, der Struktur der Bauindustrie und Methoden des Wissenstransfers. Der zweite Teil konzentriert sich auf die Analyse, insbesondere die Transfer- und Zielgruppenanalyse. Teil drei umfasst die Definition und Konzeption der Arbeit mit Kapiteln zur Persona-Erstellung und zur Bewertung verschiedener Konzeptvarianten in einem Expertenworkshop. Der vierte Teil widmet sich dem Entwurf und der Ausarbeitung, wobei ein Schwerpunkt auf der Entwicklung eines App-Demonstrators liegt. Schließlich beschreibt Teil fünf die Ergebnisse der Arbeit, einschließlich der Beschreibung des App-Demonstrators und der zugehörigen Nutzerreise. Die Arbeit schließt mit einer Diskussion ihrer Grenzen und zukünftigen Aussichten ab. Insgesamt zielt die Diplomarbeit darauf ab, die Baubranche bei der Bewältigung der aktuellen Herausforderungen und Veränderungen zu unterstützen, indem sie innovative Technologien und Designprinzipien einsetzt, um Kommunikation und Wissenstransfer zu verbessern und den Bedürfnissen der Endnutzenden gerecht zu werden.},
  keywords = {notion},
  file = {/Users/vituspacholleck/Library/CloudStorage/GoogleDrive-vituspach@gmail.com/My Drive/Obsidian/Wandelbots/PDFs/Engler 2023.pdf}
}

