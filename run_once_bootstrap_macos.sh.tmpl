{{- if eq .chezmoi.os "darwin" -}}
#!/bin/bash
set -euo pipefail

export PATH="$HOME/bin:$HOME/.local/bin:$PATH"

CHEZMOI_BIN="$(command -v chezmoi || true)"
if [[ -z "$CHEZMOI_BIN" && -x "$HOME/bin/chezmoi" ]]; then
	CHEZMOI_BIN="$HOME/bin/chezmoi"
elif [[ -z "$CHEZMOI_BIN" && -x "$HOME/.local/bin/chezmoi" ]]; then
	CHEZMOI_BIN="$HOME/.local/bin/chezmoi"
fi

if [[ -z "$CHEZMOI_BIN" ]]; then
	echo "chezmoi not found in PATH or common install locations"
	exit 1
fi

SOURCE_DIR="$($CHEZMOI_BIN source-path)"

"$SOURCE_DIR/bootstrap/install_brew.sh"
"$SOURCE_DIR/bootstrap/apps_brew.sh"
"$SOURCE_DIR/bootstrap/install_oh_my_zsh.sh"
"$SOURCE_DIR/bootstrap/setup_lazyvim.sh"
"$SOURCE_DIR/bootstrap/macos_defaults.sh"
"$SOURCE_DIR/bootstrap/macos_duti.sh"
"$SOURCE_DIR/bootstrap/macos_marta.sh"
"$SOURCE_DIR/bootstrap/macos_mas.sh"
"$SOURCE_DIR/bootstrap/repos.sh"
"$SOURCE_DIR/bootstrap/vscode_extensions.sh"
{{- end -}}
