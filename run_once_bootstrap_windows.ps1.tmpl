{{- if eq .chezmoi.os "windows" -}}
$ErrorActionPreference = "Stop"

$env:Path = "$HOME\bin;$HOME\.local\bin;$env:Path"

$chezmoi = Get-Command chezmoi -ErrorAction SilentlyContinue
if (-not $chezmoi -and (Test-Path "$HOME\bin\chezmoi.exe")) {
	$chezmoiPath = "$HOME\bin\chezmoi.exe"
}
elseif (-not $chezmoi -and (Test-Path "$HOME\.local\bin\chezmoi.exe")) {
	$chezmoiPath = "$HOME\.local\bin\chezmoi.exe"
}
elseif ($chezmoi) {
	$chezmoiPath = $chezmoi.Source
}
else {
	throw "chezmoi not found in PATH or common install locations"
}

$sourceDir = & $chezmoiPath source-path

& "$sourceDir\bootstrap\install_scoop.ps1"
& "$sourceDir\bootstrap\apps_scoop.ps1"
& "$sourceDir\bootstrap\apps_winget.ps1"
& "$sourceDir\bootstrap\repos.ps1"
& "$sourceDir\bootstrap\vscode_extensions.ps1"
& "$sourceDir\bootstrap\windows_bloatware.ps1"
& "$sourceDir\bootstrap\windows_hardening.ps1"
& "$sourceDir\bootstrap\windows_registry.ps1"
& "$sourceDir\bootstrap\windows_services.ps1"
{{- end -}}
