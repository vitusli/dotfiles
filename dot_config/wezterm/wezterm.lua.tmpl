config.show_new_tab_button_in_tab_bar = false

local tab_bar_cols = 0

local function update_tab_bar_cols(window)
  local success, tab = pcall(function()
    return window:active_tab()
  end)

  if success and tab then
    local size = tab:get_size()
    if size and size.cols then
      tab_bar_cols = size.cols
    end
  end
end

wezterm.on('window-config-reloaded', function(window)
  update_tab_bar_cols(window)
end)

wezterm.on('window-resized', function(window, _)
  update_tab_bar_cols(window)
end)

local function tab_title(tab_info)
  local title = tab_info.tab_title
  if title and #title > 0 then
    return title
  end
  return tab_info.active_pane.title or 'shell'
end

-- Best-effort equal-width tabs for the retro tab bar.
wezterm.on('format-tab-title', function(tab, tabs, panes, config, hover, max_width)
  local title = tab_title(tab)
  local tab_count = math.max(#tabs, 1)
  local target_width = max_width

  if tab_bar_cols > 0 then
    local base_width = math.floor(tab_bar_cols / tab_count)
    local remainder = tab_bar_cols % tab_count
    target_width = base_width + (tab.tab_index < remainder and 1 or 0)
  end

  target_width = math.max(math.min(target_width, max_width), 1)

  if #title > target_width then
    title = wezterm.truncate_right(title, target_width - 1) .. '…'
  end

  local padding = math.max(target_width - #title, 0)
  local left_padding = math.floor(padding / 2)
  local right_padding = padding - left_padding

  return {
    { Text = string.rep(' ', left_padding) .. title .. string.rep(' ', right_padding) },
  }
end)

