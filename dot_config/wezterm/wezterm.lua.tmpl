-- WezTerm Configuration
-- Cross-platform config with OS-specific keybindings

local wezterm = require 'wezterm'
local config = wezterm.config_builder()

-- Detect system appearance (Dark/Light)
local function get_appearance()
  if wezterm.gui then
    return wezterm.gui.get_appearance()
  end
  return 'Dark'
end

{{- if eq .chezmoi.os "darwin" }}
-- macOS: Force wezterm launch in foreground
wezterm.on("gui-startup", function(cmd)
  local _, _, window = wezterm.mux.spawn_window(cmd or {})
  window:gui_window():focus()
end)
{{- end }}

-- ==========================
-- Font
-- ==========================
config.font = wezterm.font('JetBrains Mono', { weight = 'Medium' })
{{- if eq .chezmoi.os "darwin" }}
config.font_size = 12.0
{{- end }}
{{- if eq .chezmoi.os "windows" }}
config.font_size = 9.0
{{- end }}
{{- if eq .chezmoi.os "linux" }}
config.font_size = 9.0
{{- end }}
config.line_height = 1.2

-- ==========================
-- Window Appearance
-- ==========================
config.window_decorations = "RESIZE"
config.window_padding = {
  left = 40,
  right = 40,
  top = 60,
  bottom = 60,
}

-- Disable annoying close confirmation
config.window_close_confirmation = 'NeverPrompt'

-- ==========================
-- Colors & Themes
-- ==========================

-- Cursor Dark Midnight (Your custom theme)
local cursor_dark_midnight = {
  background = '#191c22',
  foreground = '#7b88a1',
  cursor_bg = '#8fbcbb',
  cursor_fg = '#191c22',
  cursor_border = '#8fbcbb',
  selection_bg = '#21242b',
  selection_fg = '#7b88a1',
  ansi = {
    '#3b4252', '#bf616a', '#a3be8c', '#ebcb8b',
    '#81a1c1', '#b48ead', '#88c0d0', '#e5e9f0',
  },
  brights = {
    '#4c566a', '#bf616a', '#a3be8c', '#ebcb8b',
    '#81a1c1', '#b48ead', '#8fbcbb', '#eceff4',
  },
  tab_bar = {
    background = '#191c22',
    active_tab = { bg_color = '#21242b', fg_color = '#e5e9f0', intensity = 'Bold' },
