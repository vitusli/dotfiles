    new_tab_hover = { bg_color = '#21242b', fg_color = '#7b88a1' },
  },
}

-- Cursor Light (approximate from VSCode theme)
local cursor_light = {
  background = '#ffffff',
  foreground = '#383a42',
  cursor_bg = '#526fff',
  cursor_fg = '#ffffff',
  cursor_border = '#526fff',
  selection_bg = '#e5ebff',
  selection_fg = '#383a42',
  ansi = {
    '#383a42', '#e45649', '#50a14f', '#c18401',
    '#4078f2', '#a626a4', '#0184bc', '#a0a1a7',
  },
  brights = {
    '#383a42', '#e45649', '#50a14f', '#c18401',
    '#4078f2', '#a626a4', '#0184bc', '#a0a1a7',
  },
  tab_bar = {
    background = '#f3f3f3',
    active_tab = { bg_color = '#ffffff', fg_color = '#383a42', intensity = 'Bold' },
    inactive_tab = { bg_color = '#f3f3f3', fg_color = '#6a6a6a' },
    inactive_tab_hover = { bg_color = '#e5ebff', fg_color = '#383a42' },
    new_tab = { bg_color = '#f3f3f3', fg_color = '#6a6a6a' },
    new_tab_hover = { bg_color = '#e5ebff', fg_color = '#383a42' },
  },
}

-- Apply theme based on appearance
if get_appearance():find 'Dark' then
  config.colors = cursor_dark_midnight
  config.command_palette_bg_color = '#191c22'
  config.command_palette_fg_color = '#d8dee9'
else
  config.colors = cursor_light
  config.command_palette_bg_color = '#ffffff'
  config.command_palette_fg_color = '#383a42'
end

config.command_palette_font_size = 14.0
config.command_palette_rows = 12

-- ==========================
-- Tab Bar
-- ==========================
config.enable_tab_bar = true
config.hide_tab_bar_if_only_one_tab = true
config.use_fancy_tab_bar = false  -- Retro tab bar looks cleaner
config.tab_max_width = 32
config.show_tab_index_in_tab_bar = false
config.show_new_tab_button_in_tab_bar = false

-- Custom tab title
wezterm.on('format-tab-title', function(tab, tabs, panes, config, hover, max_width)
  local title = tab.active_pane.title
  if title and #title > max_width - 4 then
    title = wezterm.truncate_right(title, max_width - 4) .. '…'
  end
  return {
    { Text = ' ' .. title .. ' ' },
  }
end)

-- ==========================
-- Keybindings
-- ==========================
-- macOS: CMD as modifier
-- Windows/Linux: CTRL as modifier

{{- if eq .chezmoi.os "darwin" }}
local mod = 'CMD'
local mod_shift = 'CMD|SHIFT'
local mod_alt = 'CMD|ALT'
{{- end }}
{{- if eq .chezmoi.os "windows" }}
local mod = 'CTRL'
local mod_shift = 'CTRL|SHIFT'
local mod_alt = 'CTRL|ALT'
{{- end }}
{{- if eq .chezmoi.os "linux" }}
local mod = 'CTRL'
local mod_shift = 'CTRL|SHIFT'
local mod_alt = 'CTRL|ALT'
{{- end }}

config.keys = {
  -- Command Palette
  {
    key = 'p',
    mods = mod_shift,
    action = wezterm.action.ActivateCommandPalette,
  },

  -- Split Navigation - h/j/k/l
  {
    key = 'h',
    mods = mod_shift,
    action = wezterm.action.ActivatePaneDirection 'Left',
  },
  {
    key = 'j',
    mods = mod_shift,
    action = wezterm.action.ActivatePaneDirection 'Down',
  },
  {
    key = 'k',
    mods = mod_shift,
    action = wezterm.action.ActivatePaneDirection 'Up',
  },
  {
    key = 'l',
    mods = mod_shift,
    action = wezterm.action.ActivatePaneDirection 'Right',
  },

  -- New Split
  {
    key = 'n',
    mods = mod,
    action = wezterm.action.SplitPane {
      direction = 'Right',
      size = { Percent = 50 },
    },
  },
  {
    key = 'n',
    mods = mod_shift,
    action = wezterm.action.SplitPane {
      direction = 'Down',
      size = { Percent = 50 },
    },
  },

  -- Equalize Splits
  {
    key = 'e',
    mods = mod_shift,
    action = wezterm.action.Multiple {
      wezterm.action.AdjustPaneSize { 'Left', 100 },
      wezterm.action.AdjustPaneSize { 'Right', 100 },
      wezterm.action.AdjustPaneSize { 'Up', 100 },
      wezterm.action.AdjustPaneSize { 'Down', 100 },
    },
  },

  -- Toggle Pane Zoom
  {
    key = ' ',
    mods = 'CTRL',
    action = wezterm.action.TogglePaneZoomState,
  },

  -- Tab Management
  {
    key = 't',
    mods = mod,
    action = wezterm.action.SpawnTab 'CurrentPaneDomain',
  },
  {
    key = 'w',
    mods = mod,
    action = wezterm.action.CloseCurrentPane { confirm = false },
  },
  {
    key = 'RightArrow',
    mods = mod_alt,
    action = wezterm.action.ActivateTabRelative(1),
  },
  {
    key = 'LeftArrow',
    mods = mod_alt,
    action = wezterm.action.ActivateTabRelative(-1),
  },

  -- Clear Terminal
  {
    key = 'k',
    mods = mod,
    action = wezterm.action.ClearScrollback 'ScrollbackAndViewport',
  },
}

-- ==========================
-- Additional Settings
-- ==========================
config.unzoom_on_switch_pane = true
config.scrollback_lines = 10000

-- Default shell
{{- if eq .chezmoi.os "darwin" }}
config.default_prog = { '/bin/zsh', '-l' }
{{- end }}
{{- if eq .chezmoi.os "windows" }}
config.default_prog = { 'pwsh.exe', '-NoLogo' }
{{- end }}
{{- if eq .chezmoi.os "linux" }}
config.default_prog = { '/usr/bin/zsh', '-l' }
{{- end }}

return config
