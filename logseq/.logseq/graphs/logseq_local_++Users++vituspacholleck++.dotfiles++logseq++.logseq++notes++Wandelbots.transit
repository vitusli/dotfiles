,"^U",4,536870919]],["^15",[152,"^U",37,536870919]],["^15",[152,"^U",118,536870919]],["^15",[152,"^H",4,536870919]],["^15",[152,"^H",37,536870919]],["^15",[152,"^;","~u66975907-9b5d-4e84-8da4-9cd229d9d8ce",536870919]],["^15",[153,"^3","- [[MPI]]\n\t- [[Work in progress]]\n\t\t- Drei Ansichten: Lab, Demo, NOVA viewport\n- ### [[Protokoll]]\n  people:: [[Tom Schmiedel]]\n  projekt:: [[MPI]] \n  tags:: [[Internal Update]]\n\t- Was macht die Pumpe?\n\t- Welche Signale braucht die Pumpe?\n\t\t- An/Aus\n\t\t  :LOGBOOK:\n\t\t  CLOCK: [2024-07-04 Thu 16:02:58]--[2024-07-04 Thu 16:02:58] =>  00:00:00\n\t\t  :END:\n\t\t- Welcher Schlauch ist wann aktiv? Kann ich auswählen?\n\t\t- Pump-Richtung\n\t- Signale - Möglichkeit:\n\t\t- Wandelskript bei uns im Wandelscript\n\t\t  logseq.order-list-type:: number\n\t\t- Labview bei Kyle\n\t\t  logseq.order-list-type:: number\n\t- Was macht Kyle mit der Pumpe?\n\t- Wo kommt das Reinigungsmittel her?\n\t- [[Mail]]\n\t\t- Von [[Tom Schmiedel]] an [[Kyle Wellmerling]]\n\t\t\t- How do you control the pump? I think over LabView à USB, correct?\n\t\t\t- What commands you are using to control the pump? (e.g. start pump (H), stop pump (I),…) Do you have like a flow chart for the communication?\n\t\t\t- Were you able to select the pipe in which the liquid is pumped or does the pump pumps the liquid through all connected pipes at the same time?\n\t\t\t  For the Wandelbots integration we have 2 possibilities:\n\t\t\t- We integrate the pump via RS232 in our system and could control the pump independent.\n\t\t\t- We will provide several (you have to tell us how many) inputs and outputs (e.g. via relay) and you integrate them into LabView. \n\t\t\t  What way do you prefer?\n- [[Omniverse]]\n\t- [[Stored knowledge]]\n\t\t- [[Endeffektor]]\n\t\t\t- Erst Endeffektor auswählen, dann 6. Glied\n\t\t\t- Create/Physics/Joint/Fixed Joint\n\t\t\t- Collider erstellen über Add/Physics/Rigid body - unbedingt auf dem obersten Xform\n\t\t\t- tool_endeffektor anwählen, link_06 mit strg auswählen - create fix joints\n\t\t\t- Tool zeigt in X\n\t\t- Jogging funktioniert nur im Root Layer, nicht in anderen Layern\n\t\t- [Camera Animation Extension]({{video https://www.youtube.com/watch?v=mAcFVeb0MsE}})\n- ### TODOs\n\t- [[TODO/General]]\n\t\t- DONE VPN",536870919]],["^15",[153,"^1A",1721194759453,536870919]],["^15",[153,"^Z","journals/2024_07_04.md",536870919]],["^15",[154,"^K",1721194759678,536870919]],["^15",[154,"^@",false,536870919]],["^15",[154,"^Y","mail",536870919]],["^15",[154,"^11","Mail",536870919]],["^15",[154,"^B",1721194759678,536870919]],["^15",[154,"^;","~u66975907-4db9-4b85-ae5d-7d77ae8350bf",536870919]],["^15",[155,"^K",1721194759728,536870919]],["^15",[155,"^[",962,536870919]],["^15",[155,"^@",false,536870919]],["^15",[155,"^Y","omniverse",536870919]],["^15",[155,"^11","Omniverse",536870919]],["^15",[155,"^?",["^ ","^1G",["^1E",["Omniverse Thoughts","OV"]]],536870919]],["^15",[155,"^4",["^ ","^1G","[[Omniverse Thoughts]] [[OV]]"],536870919]],["^15",[155,"^P",812,536870919]],["^15",[155,"^P",963,536870919]],["^15",[155,"^B",1721194759728,536870919]],["^15",[155,"^;","~u66975907-9b3a-4c19-8dd3-1ed59252e2cd",536870919]],["^15",[156,"^K",1721194759452,536870919]],["^15",[156,"^[",153,536870919]],["^15",[156,"^N",20240704,536870919]],["^15",[156,"^@",true,536870919]],["^15",[156,"^Y","2024-07-04",536870919]],["^15",[156,"^11","2024-07-04",536870919]],["^15",[156,"^B",1721194759452,536870919]],["^15",[156,"^;","~u66975907-7297-45e4-a000-a0b3f8b488fe",536870919]],["^15",[157,"^K",1721194759777,536870919]],["^15",[157,"^@",false,536870919]],["^15",[157,"^Y","work in progress",536870919]],["^15",[157,"^11","Work in progress",536870919]],["^15",[157,"^B",1721194759777,536870919]],["^15",[157,"^;","~u66975907-1168-4f04-ae4c-d7c47eaf270a",536870919]],["^15",[158,"^K",1721194759719,536870919]],["^15",[158,"^[",948,536870919]],["^15",[158,"^@",false,536870919]],["^15",[158,"^Y","mpi",536870919]],["^15",[158,"^11","MPI",53687091