77,"^F",472,536870919]],["^15",[477,"^10","DONE",536870919]],["^15",[477,"^X",464,536870919]],["^15",[477,"^V",472,536870919]],["^15",[477,"^U",4,536870919]],["^15",[477,"^U",7,536870919]],["^15",[477,"^U",34,536870919]],["^15",[477,"^U",464,536870919]],["^15",[477,"^H",7,536870919]],["^15",[477,"^;","~u66975907-da7d-42cc-b1e3-a135fce858c1",536870919]],["^15",[478,"^Q","workpiece_xxx",536870919]],["^15",[478,"^O","^16",536870919]],["^15",[478,"^F",465,536870919]],["^15",[478,"^X",464,536870919]],["^15",[478,"^V",468,536870919]],["^15",[478,"^U",4,536870919]],["^15",[478,"^U",7,536870919]],["^15",[478,"^U",34,536870919]],["^15",[478,"^U",464,536870919]],["^15",[478,"^;","~u66975907-a5f1-4228-bb2b-8a6ccfffb8b7",536870919]],["^15",[479,"^Q","[[TODO/Microsoft EC]]",536870919]],["^15",[479,"^O","^16",536870919]],["^15",[479,"^F",470,536870919]],["^15",[479,"^X",464,536870919]],["^15",[479,"^V",475,536870919]],["^15",[479,"^U",4,536870919]],["^15",[479,"^U",100,536870919]],["^15",[479,"^U",464,536870919]],["^15",[479,"^H",4,536870919]],["^15",[479,"^H",100,536870919]],["^15",[479,"^;","~u66975907-b828-40c6-99e6-cfd77c4486d6",536870919]],["^15",[480,"^Q","DONE Stimmt alles?",536870919]],["^15",[480,"^O","^16",536870919]],["^15",[480,"^F",470,536870919]],["^15",[480,"^10","DONE",536870919]],["^15",[480,"^X",464,536870919]],["^15",[480,"^V",470,536870919]],["^15",[480,"^U",4,536870919]],["^15",[480,"^U",7,536870919]],["^15",[480,"^U",34,536870919]],["^15",[480,"^U",464,536870919]],["^15",[480,"^H",7,536870919]],["^15",[480,"^;","~u66975907-ebf5-4817-91ce-ab5dc262148e",536870919]],["^15",[481,"^Q","DONE Export in Blender",536870919]],["^15",[481,"^O","^16",536870919]],["^15",[481,"^F",474,536870919]],["^15",[481,"^10","DONE",536870919]],["^15",[481,"^X",464,536870919]],["^15",[481,"^V",473,536870919]],["^15",[481,"^U",4,536870919]],["^15",[481,"^U",7,536870919]],["^15",[481,"^U",34,536870919]],["^15",[481,"^U",464,536870919]],["^15",[481,"^H",7,536870919]],["^15",[481,"^;","~u66975907-91f6-4a31-84ef-62b54b6ca63f",536870919]],["^15",[482,"^Q","[[TODO/Asset Library]]",536870919]],["^15",[482,"^O","^16",536870919]],["^15",[482,"^F",479,536870919]],["^15",[482,"^X",464,536870919]],["^15",[482,"^V",475,536870919]],["^15",[482,"^U",4,536870919]],["^15",[482,"^U",37,536870919]],["^15",[482,"^U",464,536870919]],["^15",[482,"^H",4,536870919]],["^15",[482,"^H",37,536870919]],["^15",[482,"^;","~u66975907-dc91-4b9e-8ef8-2bb1ce790514",536870919]],["^15",[483,"^Q","DONE UV unwrapping\n:LOGBOOK:\nCLOCK: [2024-06-13 Thu 11:39:54]--[2024-06-13 Thu 11:39:54] =>  00:00:00\n:END:",536870919]],["^15",[483,"^O","^16",536870919]],["^15",[483,"^F",466,536870919]],["^15",[483,"^10","DONE",536870919]],["^15",[483,"^X",464,536870919]],["^15",[483,"^V",481,536870919]],["^15",[483,"^U",4,536870919]],["^15",[483,"^U",7,536870919]],["^15",[483,"^U",34,536870919]],["^15",[483,"^U",464,536870919]],["^15",[483,"^H",7,536870919]],["^15",[483,"^;","~u66975907-ffb8-4eff-9931-525073464dd1",536870919]],["^15",[484,"^3","### [[Protokoll]]\npeople:: [[Paul Weiss]] \nprojekt:: [[MPI]] \ntags:: [[Teaching]] [[Omniverse]] [[Endeffektor]] [[Stored Knowledge]]\n\t- DONE den Salat hier ordnen\n\t- ### Vorarbeit\n\t\t- Origins individuell in Rhino setzen\n\t\t\t- Transforms (Translation, Rotation) individuell festlegen\n\t\t- Alle Dateien in Omniverse öffnen und in die \"Golden Standard\" Struktur überführen\n\t- ### Hauptteil\n\t\t- In Omniverse alle Arbeitsgeräte in den Roboter_Workspace ziehen\n\t\t\t- workspace_ur5\n\t\t\t\t- tcp_xxx (tcp_tip)\n\t\t\t\t\t- mit **!_distance** messen in Rhino\n\t\t\t\t\t\t- 0 bis tcp\n\t\t\t\t- tool_xxx (tool_endeffktor)\n\t\t\t\t\t- muss an den Roboter-Flansch ran\n\t\t\t\t\t  :LOGBOOK:\n\t\t\t\t\t  CLOCK: [2024-06-12 Wed 16:51:46]\n\t\t\t\t\t  :END:\n\t\t\t\t\t\t- copy transform des ur5 über RMB\n\t\t\t\t\t\t- paste transform des ur5 in das tool_endeffektor über RMB\n\t\t\t\t\t\t\t- die Reihenfolge von Translate, Orient, Scale muss gleich sein\n\t\t- tool_xxx (tool_endeffektor) auswählen\n\t\t\t- add > physics > rigid body\n\t\t\t\t- play: fällt runter\n\t\t\t- create > xform\n\t\t\t\t- \"tcp\" nennen\n\t\t\t\t- tcp transform\n\t\t\t\t\t- add (großes, grünes plus neben dem Namen in den Properties)\n\t\t\t\t\t\t- TransformOP > \"Translate, Orient, Scale\"\n\t\t\t\t\t- die in Rhino gemessenen Werte eingeben\n\t\t\t\t\t\t- tcp xform sitzt jetzt an der gleichen Stelle, wie der Origin des tcp_ghost_teachings\n\t\t- workpiece_xxx (workpiece_endeffektor) platzieren\n\t\t- tcp_xxx_ghost_teaching (tcp_tip_ghost_teaching) an die Arbeitspunkte platzieren (duplizieren)\n\t- ### Developer Portal\n\t\t- Roboter anlegen im Developer Portal\n\t\t\t- Custom Config um tcp einzustellen\n\t\t\t\t- <DEINEINSTANZ>/api/v1/internal/ui\n\t\t\t\t\t- http://mfiobowy.instance.wandelbots.io/api/v1/internal/ui\n\t\t\t\t\t- virtual robot setup\n\t\t\t\t\t- Add TCP\n\t\t\t\t\t\t- name bei controller\n\t\t\t\t\t\t- id* ist 0\n\t\t\t\t\t\t- tcp eingeben, Winkel in rad\n\t\t\t\t\t\t\t- send API request\n- ### [[Protokoll]]\n  people:: [[Paul Weiss]] [[Frank Mühlbauer]]\n  projekt:: [[Asset Library]]\n  tags::\n  collapsed:: true\n\t- Roboter_Workspace\n\t\t- Activate Children Reorder\n\t\t- 0/0/0\n\t\t- x/y Koordinate muss beim Reinziehen in die Szene muss immer gleich sein - Agnostik\n\t\t- TCP in die richtige Richtung\n\t\t  id:: 3a0f5faf-03c4-4cec-86ce-1e32005828c4\n\t\t\t- Z nach vorne\n\t\t\t- x/y müssen wir aus dem Datenblatt rauskriegen\n\t\t- keine Collider\n\t\t- Material-Struktur\n\t\t\t- Standard finden: Material Best Practice\n\t\t\t- Licht-Studio fürs Prüfen in Omniverse und Blender\n\t\t\t- ghost teaching Material überlegen\n\t- Kabel erst mal weg; weil die später simuliert werden könnten\n\t- ### Prio\n\t\t- [[Paul Weiss]] haut Grundmodelle ins Omniverse und schickt mir die USD\n\t\t- [[Bruno Bellmann]] checkt die Orientierung\n\t\t\t- wir müssen ihm unsere Anforderungen mitteilen\n\t\t- [[Vitus Pacholleck]] kümmert sich ums Chirurgische\n\t- Excell Tabelle\n\t\t- Source of Prooth\n\t\t-\n\t- Nach der Roboter-Bibliothek kommt die Tool-Bibliothek\n\t-\n- ## [[Protokoll]]\n  people:: [[Paul Weiss]] [[Frank Mühlbauer]] [[CPS]] [[Johannes Baumgärtel]]\n  projekt:: [[SPS'24]]\n  tags:: [[Launch Concept]]\n  collapsed:: true\n\t- ### Thinkspace\n\t\t- Sehgewohnheiten brechen\n\t\t- Insel\n\t\t\t- Alles abgehängt, von oben\n\t\t\t- Roboter interagieren (Übergabe) miteinander\n\t\t\t- nicht fertig als Setup - Nutzende können mit den Robotern interagieren/manipulieren\n\t\t\t\t- Screen von der Decke abgehängt\n\t\t\t\t- Alle Robs in eigener Zelle\n\t\t\t\t- Klassische, nicht abstrakte Aufgaben\n\t\t- Tesla Beispiel: die haben ne Software und bauen ein Auto drum rum\n\t\t- Was bedeutet das für NOVA?\n\t\t- Wie stellt man Software dar?\n\t\t\t- SPS'23: Plan - Build - Operate\n\t\t\t\t- suggeriert drei Schwerpunkte\n\t\t- Was ist der Schwerpunkt unserer Software?\n\t\t- Sind wir noch auf der Suche oder verkaufen wir schon?\n\t\t\t- Die Suche ist vorbei - das transportieren wir nach außen  - wir wollen 500 user bis Ende 2024\n\t\t\t\t- **Ideen**\n\t\t\t\t\t- Wie würden ganz eingestaubte Vertriebler das verkaufen? Windows95 Boxen im Regal\n\t\t\t\t\t- Nutzende sollen Ihre eigenen Gedanken kriegen: \"Ah, das könnte ich für meine Palettier-Aufgabe nutzen!\"\n\t\t\t\t\t- Roboter in vier Farben\n\t\t\t\t\t\t- die übergeben sich gegenseitig Aufgaben\n\t\t\t\t\t\t- Pfade werden in Echtzeit geändert\n\t\t\t\t\t\t- Kollision: Roboter arbeiten umeinander rum\n\t\t\t\t\t\t\t- Vernetzung\n\t\t\t\t\t- All In-Veranstaltung: nicht zurückhalten\n\t\t\t\t\t\t- Allerdings können wir das alles noch gar nicht\n\t\t\t\t\t\t\t- Roboter Interkation\n\t\t\t\t\t\t\t- Multi Robot\n\t\t\t\t\t\t\t- Cloud\n\t\t\t\t\t\t- Wir müssen uns darauf fokussieren, was wir schon können\n\t\t\t\t\t\t\t- Anforderungen der Nutzenden beeinflussen die Software, aber wir sollten nicht sagen \"Das können wir schon.\"\n\t\t\t\t\t\t- Wir sollten zeigen: du kannst Cloud, Kabel etc pp nutzen - sonst schrecken wir Leute aus der Industrie ab\n\t\t\t- Wie würde der Messestand nächste Woche eigentlich aussehen? Was können wir jetzt schon richtig gut?\n\t\t\t\t- Repräsentieren, was wir schon können, reicht nicht - sagt CPS\n\t\t\t- Workstation\n\t\t\t\t- Omniverse Setup\n\t\t\t\t- Kollision anzeigen lassen\n\t\t\t\t- Erst planen in Omniverse - dann in die echte Welt übertragen\n\t\t\t\t- Alle Roboter in gleicher Gewichtsklasse und Preisklasse\n\t\t\t\t\t- Keine Präferenzen\n\t\t\t\t\t- Kein Univeral Robot\n\t\t\t\t\t\t- fällt aus dem Raster\n\t\t\t\t\t\t- ist für sich schon sehr weit in der Entwicklung\n\t\t\t\t\t-\n\t\t- ### Aufgaben\n\t\t\t- CAD Modell und mal gucken, ob 80qm reichen für 4 Roboter\n\t\t\t- Möbel aus Libray von [[Vitus Pacholleck]]\n\t\t\t- Auftrennen\n\t\t\t\t- Business\n\t\t\t\t- Anwendung\n-\n-\n- # [[TODOs]]",536870919]],["^15",[484,"^1A",1721194759582,536870919]],["^15",[484,"^Z","journals/2024_06_12.md",536870919]],["^15",[485,"^K",1721194759581,536870919]],["^15",[485,"^@",false,536870919]],["^15",[485,"^Y","launch concept",536870919]],["^15",[485,"^11","Launch Concept",536870919]],["^15",[485,"^B",1721194759581,536870919]],["^15",[485,"^;","~u66975907-2954-4032-b787-eb0ccb71ec6a",536870919]],["^15",[486,"^K",1721194759581,536870919]],["^15",[486,"^@",false,536870919]],["^15",[486,"^Y","sps'24",536870919]],["^15",[486,"^11","SPS'24",536870919]],["^15",[486,"^B",1721194759581,536870919]],["^15",[486,"^;","~u66975907-bb4c-4d12-a83a-b74fc5d9bc0a",536870919]],["^15",[487,"^K",1721194759581,536870919]],["^15",[487,"^@",false,536870919]],["^15",[487,"^Y","vitus pacholleck",536870919]],["^15",[487,"^11","Vitus Pacholleck",536870919]],["^15",[487,"^B",1721194759581,536870919]],["^15",[487,"^;","~u66975907-f536-471c-b011-ad866430d4b4",536870919]],["^15",[488,"^K",1721194759579,536870919]],["^15",[488,"^[",484,536870919]],["^15",[488,"^N",20240612,536870919]],["^15",[488,"^@",true,536870919]],["^15",[