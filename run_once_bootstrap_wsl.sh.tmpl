{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

if [[ -z "${WSL_DISTRO_NAME:-}" ]]; then
  echo "Skipping WSL bootstrap: linux detected but not WSL."
  exit 0
fi

SOURCE_DIR="{{ .chezmoi.sourceDir }}"

"$SOURCE_DIR/bootstrap/apps_apt.sh"
"$SOURCE_DIR/bootstrap/install_brew.sh"
"$SOURCE_DIR/bootstrap/apps_brew.sh"
"$SOURCE_DIR/bootstrap/wsl_set_default_shell.sh"
"$SOURCE_DIR/bootstrap/repos.sh"
"$SOURCE_DIR/bootstrap/setup_lazyvim.sh"
{{- end -}}
