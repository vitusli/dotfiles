{
  "languages": {
    "Typst": {
      "soft_wrap": "editor_width"
    },
    "Markdown": {
      "soft_wrap": "editor_width"
    }
  },
  "disable_ai": true,
  "tab_bar": {
    "show": true
  },
  "title_bar": {
    "show_onboarding_banner": false,
    "show_sign_in": false,
    "show_user_picture": false
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "notify_when_agent_waiting": "never",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4-6"
    },
    "model_parameters": []
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 10000
    }
  },
  "session": {
    "trust_all_worktrees": true
  },
  "vim_mode": true,
  "base_keymap": "VSCode",
  "ui_font_size": 14,
  "buffer_font_size": 14,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },
  "file_scan_exclusions": [
    "**/.venv",
    "**/__pycache__",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/.ruff_cache",
    "**/.tox",
    "**/.nox",
    "**/_reference"
  ],
  "lsp": {
    "tinymist": {
      "initialization_options": {
        "preview": {
          "background": {
            "enabled": true
          }
        }
      }
    }
  }
}
