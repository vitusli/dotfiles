{{- $mod := "ctrl" }}
{{- if eq .chezmoi.os "darwin" }}
{{- $mod = "cmd" }}
{{- end }}
[
  {
    "context": "vim_mode == visual",
    "bindings": {
      "shift-s": "vim::PushAddSurrounds"
    }
  },
{{- if eq .chezmoi.os "windows" }}
  {
    "context": "vim_mode == normal || vim_mode == insert || vim_mode == visual",
    "bindings": {
      "ctrl-1": "editor::ToggleFocus",
      "ctrl-b": "workspace::ToggleLeftDock",
      "ctrl-j": "terminal_panel::ToggleFocus"
    }
  },
  {
    "context": "vim_mode == normal || vim_mode == insert",
    "bindings": {
      "ctrl-alt-o": "projects::OpenRecent"
    }
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "ctrl-p": "file_finder::Toggle"
    }
  },
  {
    "context": "vim_mode == insert",
    "bindings": {
      "ctrl-v": "editor::Paste"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-b": "workspace::ToggleLeftDock",
      "ctrl-p": "file_finder::Toggle"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-p": "file_finder::Toggle"
    }
  },
{{- end }}
  {
    "bindings": {
{{- if eq .chezmoi.os "windows" }}
      "ctrl-1": "editor::ToggleFocus",
{{- end }}
      "{{ $mod }}-i": "agent::ToggleFocus",
      "{{ $mod }}-shift-j": "terminal_panel::ToggleFocus"
    }
  }
]
