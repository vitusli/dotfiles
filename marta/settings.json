behavior {
    theme "Nord"
    layout {
        showActionBar false
    }
    quickSelect {
        activateOnAnyCharacter false
        
    }
}



keyBindings {
    "a" "core.select.all"

    "s" "core.ordering"
    "Cmd+K" "core.actions"
    
    "Tab" "core.change.current.pane"
    "G" "core.move"
    "I" "core.finder.showInfo"
    
    "K" "core.move.up"
    "Shift+K" "core.select.move.up"
    "J" "core.move.down"
    "Shift+J" "core.select.move.down"
    
    "g" "core.move.left"
    "Shift+G" "core.move.right"
    
    
    "." "core.refresh"
    
    
    "V" "core.volumes"
    "F" "core.favorites"
    "Shift+F" "core.favorites.add"
    
    "O" "core.open.with"
    "H" "core.go.up"
    "L" "core.open"
    
    
    "Cmd+/" "core.lookup"
    
    "Y" "core.clipboard.copy"
    "P" "core.clipboard.paste"
    
    "R" "core.rename"
    
    "N" "core.new.folder"
    "Shift+N" "core.new.file"
    
    "D" "core.trash"
    
    "Cmd+Shift+P" "core.path.folder"
    "Cmd+P" "core.path"
    
    "X" "core.move.inactive"
    "C" "core.copy.inactive"
    "Shift+H" "core.display.hidden"
    
    "Cmd+F" "core.finder.reveal"
    
    "Alt+H" {
        id "core.open.directory"
        src "~"
    }
    
}